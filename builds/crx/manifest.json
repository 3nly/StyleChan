{
  "name": "StyleChan",
  "version": "1.7.3",
  "manifest_version": 2,
  "description": "Customizable themes for 4chan X.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [{
    "js": ["script.js"],
    "matches": ["*://boards.4chan.org/*","*://sys.4chan.org/*"],
    "exclude_matches": ["*://www.4chan.org/","*://www.4chan.org/*","*://www.4chan.org/advertise*","*://www.4chan.org/donate*","*://www.4chan.org/pass*","*://sys.4chan.org/signin*","*://sys.4chan.org/auth*"],
    "all_frames": true,
    "run_at": "document_start"
  }],
  "homepage_url": "https://github.com/3nly/StyleChan/",
  "update_url": "https://github.com/3nly/StyleChan/releases/latest/download/updates.xml",
  "permissions": [
    "storage",
    "*://boards.4chan.org/*",
    "*://sys.4chan.org/*"
  ]
}
